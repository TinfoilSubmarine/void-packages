	vdoc README.md
	vsconf sample-ddclient-wrapper.sh
	vsconf sample-etc_cron.d_ddclient
	vsconf ddclient.conf
	vsconf sample-etc_dhclient-exit-hooks
	vsconf sample-etc_dhcpc_dhcpcd-eth0.exe
	vsconf sample-etc_ppp_ip-up.local
	vsv ddclient
}
